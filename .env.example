# Copy to `.env.local` for local development (never commit real secrets).

# --- Bootstrap admin (only when Firestore has zero admins, e.g. first install / offline)
# Password must match login: use the same string you would pass to btoa() in the browser for your password.
# Example: in DevTools console: btoa('MySecret123')  → paste result below
NEXT_PUBLIC_BOOTSTRAP_ADMIN_PASSWORD_B64=
NEXT_PUBLIC_BOOTSTRAP_ADMIN_USERNAME=admin
NEXT_PUBLIC_BOOTSTRAP_ADMIN_NAME=Super Admin

# --- Firebase App Check (optional; reduces automated abuse against your Firebase APIs)
# Create reCAPTCHA v3 in Google Cloud, register the site key in Firebase Console → App Check, then:
NEXT_PUBLIC_FIREBASE_APPCHECK_KEY=
